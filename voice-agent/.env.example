# LiveKit Cloud Configuration
# Get these at https://cloud.livekit.io/
LIVEKIT_URL="YOUR_LIVEKIT_URL"
LIVEKIT_API_KEY="YOUR_LIVEKIT_API_KEY"
LIVEKIT_API_SECRET="YOUR_LIVEKIT_API_SECRET"

# LLM Provider (Gemini)
# Get this at https://aistudio.google.com/
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.0-flash-exp"

# System Prompt
SYSTEM_PROMPT="You are a professional, friendly, and efficient AI receptionist for our business. You are taking an inbound phone call. Speak clearly, concisely, and naturally. Do not use markdown syntax or emojis since your responses are being read aloud by a Text-to-Speech system. Your main goal is to assist the caller, answer common questions, and wrap up the call politely."

# TTS Provider (ElevenLabs)
# Get this at https://elevenlabs.io/
ELEVENLABS_API_KEY="YOUR_ELEVENLABS_API_KEY"
ELEVENLABS_VOICE_ID="YOUR_ELEVENLABS_VOICE_ID"
# STT Provider (Deepgram)
# Get this at https://console.deepgram.com/
DEEPGRAM_API_KEY="YOUR_DEEPGRAM_API_KEY"

# Database (Airtable)
# Create a Developer Hub Token in Airtable with 'data.records:write' permission
AIRTABLE_PAT="YOUR_AIRTABLE_PAT"
# The Base ID (find in Airtable API documentation for your base)
AIRTABLE_BASE_ID="YOUR_AIRTABLE_BASE_ID"
# The exact name of your table across the top
AIRTABLE_TABLE_NAME="call_logs"

# Agent Configuration
# Maximum time (in seconds) the agent will stay on a call before forcibly disconnecting
MAX_CALL_DURATION_SECONDS="600"

# Twilio Configuration (If initiating outbound calls or verifying webhooks)
# Get these at https://console.twilio.com/
TWILIO_ACCOUNT_SID="YOUR_TWILIO_ACCOUNT_SID"
TWILIO_AUTH_TOKEN="YOUR_TWILIO_AUTH_TOKEN"
TWILIO_PHONE_NUMBER="YOUR_TWILIO_PHONE_NUMBER"
LIVEKIT_SIP_URI="YOUR_LIVEKIT_SIP_URI"

# MongoDB Configuration
MONGODB_URI="mongodb+srv://<username>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB_NAME="stylecut_db"
